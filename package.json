{
  "name": "happy-birthday-party",
  "version": "2.0.0",
  "description": "Happy Birthday Party App - Fast Electron Version",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build-portable": "electron-builder --win portable",
    "dist": "npm run build",
    "test": "electron . --dev"
  },
  "keywords": [
    "birthday",
    "party",
    "electron",
    "desktop-app"
  ],
  "author": "Party Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {},
  "build": {
    "appId": "com.party.happybirthday",
    "productName": "HappyBirthday",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "./birthdayconfig.txt",
        "to": "./birthdayconfig.txt"
      },
      {
        "from": "./birthday.mp3",
        "to": "./birthday.mp3"
      }
    ],
    "asar": true,
    "compression": "maximum",
    "electronDownload": {
      "cache": ".electron-cache"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "HappyBirthday-Portable-${version}.exe",
      "useZip": false
    }
  }
}
